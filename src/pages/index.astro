---
import Base from "../layouts/Base.astro";
import Galaxy from "../components/Galaxy";
import Header from "../components/Header.astro";
import PointCloudHero from "../components/PointCloudHero.astro";
import Projects from "../components/Projects.astro";
import Marquee from "../components/Marquee.astro";
import Experience from "../components/Experience.astro";
import Contact from "../components/Contact.astro";
import { CV_DATA } from "../data/cv";
---

<Base title={`QANTRR | ${CV_DATA.name}`}>
  <!-- Fixed galaxy backdrop; content scrolls over it. -->
  <div class="fixed inset-0 -z-10 bg-dark pointer-events-none">
    <Galaxy
      client:load
      density={0.8}
      glowIntensity={0.18}
      saturation={0}
      twinkleIntensity={0.4}
      rotationSpeed={0.03}
      starSpeed={0.3}
      repulsionStrength={1.3}
      transparent={false}
    />
  </div>

  <Header />
  <main>
    <PointCloudHero />
    <Projects />
    <Marquee />
    <Experience />
    <Contact />
  </main>
</Base>
