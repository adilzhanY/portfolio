---
import Base from "../layouts/Base.astro";
import BlackHole from "../components/BlackHole.astro";
import Sidebar from "../components/Sidebar.astro";
import Projects from "../components/Projects.astro";
import Marquee from "../components/Marquee.astro";
import Experience from "../components/Experience.astro";
import Contact from "../components/Contact.astro";
import { CV_DATA } from "../data/cv";
---

<Base title={`QANTRR | ${CV_DATA.name}`}>
  <BlackHole />

  <!--
    Hero zone: only the black hole shows here before the content begins. The
    black hole pans up and off the top as you scroll (see uShift in
    BlackHole.astro), leaving just the starfield behind the content. Change
    h-[75vh] to taste. pointer-events-none lets drag-to-orbit reach the canvas.
  -->
  <div class="relative h-[75vh] pointer-events-none">
    <div
      id="bh-scrollcue"
      class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 transition-opacity duration-700"
    >
      <span class="font-mono text-xs uppercase tracking-[0.3em] text-muted">
        Scroll
      </span>
      <svg
        class="animate-bounce text-brand"
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M12 5v14M5 12l7 7 7-7"></path>
      </svg>
    </div>
  </div>

  <div class="flex flex-col md:flex-row gap-2 md:gap-3 p-2 md:p-3">
    <Sidebar />
    <main class="grow min-w-0 flex flex-col gap-2 md:gap-3">
      <Projects />
      <Marquee />
      <Experience />
      <Contact />
    </main>
  </div>
</Base>
