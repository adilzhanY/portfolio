---
/*
 * Fixed full-viewport particle-dust backdrop, replacing the WebGL starfield.
 * Matches the point-cloud reference art: mostly tiny white specks drifting in
 * the void, a few slowly tumbling cubes, and rare ember-orange sparks.
 * Plain Canvas 2D — cheap, pauses when the tab is hidden, and paints a single
 * still frame under prefers-reduced-motion.
 */
---

<canvas
  id="dust-canvas"
  class="fixed inset-0 -z-10 block h-full w-full bg-dark"
></canvas>

<noscript><style>#dust-canvas { display: none; }</style></noscript>

<style>
  #dust-canvas {
    touch-action: pan-y;
  }
</style>

<script>
  const canvas = document.getElementById("dust-canvas") as HTMLCanvasElement | null;
  const ctx = canvas?.getContext("2d");

  if (canvas && ctx) {
    const reduce =
      typeof matchMedia === "function" &&
      matchMedia("(prefers-reduced-motion: reduce)").matches;

    interface Speck {
      x: number;
      y: number;
      vx: number;
      vy: number;
      size: number;
      alpha: number;
      kind: "dot" | "cube" | "ember";
      rot: number;
      vrot: number;
      phase: number;
    }

    let W = 0;
    let H = 0;
    let dpr = 1;
    let specks: Speck[] = [];

    function build() {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      W = canvas.clientWidth;
      H = canvas.clientHeight;
      canvas.width = Math.max(2, Math.round(W * dpr));
      canvas.height = Math.max(2, Math.round(H * dpr));
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

      const count = Math.round(Math.min(160, (W * H) / 14000));
      specks = Array.from({ length: count }, () => {
        const r = Math.random();
        const kind: Speck["kind"] =
          r < 0.045 ? "ember" : r < 0.11 ? "cube" : "dot";
        return {
          x: Math.random() * W,
          y: Math.random() * H,
          vx: (Math.random() - 0.5) * 8,
          vy: -4 - Math.random() * 8,
          size:
            kind === "cube"
              ? 3 + Math.random() * 5
              : kind === "ember"
                ? 1 + Math.random() * 1.5
                : 0.6 + Math.random() * 1.2,
          alpha:
            kind === "dot" ? 0.15 + Math.random() * 0.5 : 0.3 + Math.random() * 0.5,
          kind,
          rot: Math.random() * Math.PI,
          vrot: (Math.random() - 0.5) * 0.4,
          phase: Math.random() * Math.PI * 2,
        };
      });
    }

    function draw(t: number, dt: number) {
      ctx.clearRect(0, 0, W, H);
      for (const s of specks) {
        s.x += s.vx * dt;
        s.y += s.vy * dt;
        s.rot += s.vrot * dt;
        if (s.y < -12) {
          s.y = H + 12;
          s.x = Math.random() * W;
        }
        if (s.x < -12) s.x = W + 12;
        if (s.x > W + 12) s.x = -12;

        if (s.kind === "cube") {
          ctx.save();
          ctx.translate(s.x, s.y);
          ctx.rotate(s.rot);
          ctx.strokeStyle = `rgba(245,245,244,${s.alpha * 0.8})`;
          ctx.lineWidth = 1;
          ctx.strokeRect(-s.size / 2, -s.size / 2, s.size, s.size);
          ctx.restore();
        } else if (s.kind === "ember") {
          const pulse = 0.55 + 0.45 * Math.sin(t * 2.2 + s.phase);
          ctx.fillStyle = `rgba(255,74,26,${s.alpha * pulse})`;
          ctx.beginPath();
          ctx.arc(s.x, s.y, s.size, 0, Math.PI * 2);
          ctx.fill();
        } else {
          ctx.fillStyle = `rgba(245,245,244,${s.alpha})`;
          ctx.fillRect(s.x, s.y, s.size, s.size);
        }
      }
    }

    let rafId = 0;
    let last = performance.now();
    const start = last;

    function tick(now: number) {
      rafId = requestAnimationFrame(tick);
      const dt = Math.min(0.1, Math.max(0, (now - last) / 1000));
      last = now;
      draw((now - start) / 1000, dt);
    }

    let resizeT = 0;
    window.addEventListener("resize", () => {
      clearTimeout(resizeT);
      resizeT = window.setTimeout(() => {
        build();
        if (reduce) draw(0, 0);
      }, 150);
    });

    build();
    if (reduce) {
      draw(0, 0);
    } else {
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) {
          cancelAnimationFrame(rafId);
          rafId = 0;
        } else if (!rafId) {
          last = performance.now();
          rafId = requestAnimationFrame(tick);
        }
      });
      rafId = requestAnimationFrame(tick);
    }
  }
</script>
