---
import { CV_DATA } from "../data/cv";

const { contact } = CV_DATA;
const links = [
  { name: "GitHub", url: contact.github, external: true },
  { name: "LinkedIn", url: contact.linkedin, external: true },
  { name: "Email", url: contact.email, external: false },
];
---

<nav class="flex gap-2 hero-fade opacity-0">
  {
    links.map((link) => (
      <a
        href={link.url}
        target={link.external ? "_blank" : undefined}
        class="hover-trigger flex-1 text-center bg-white/[0.03] border border-white/10 rounded-xl py-3 font-mono text-xs uppercase tracking-widest text-muted hover:text-brand hover:border-brand/40 transition-colors"
      >
        {link.name}
      </a>
    ))
  }
</nav>
