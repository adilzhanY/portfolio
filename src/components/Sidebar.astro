---
import { CV_DATA } from "../data/cv";
import About from "./About.astro";
import SocialLinks from "./SocialLinks.astro";
import HireMe from "./HireMe.astro";

const { education } = CV_DATA;
const firstName = CV_DATA.name.split(" ")[0];
---

<aside
  class="md:w-[360px] shrink-0 md:sticky md:top-3 md:self-start flex flex-col gap-2 md:gap-3"
>
  <!-- Profile card -->
  <div class="bg-white/[0.03] border border-white/10 rounded-2xl p-6 md:p-8">
    <div
      data-logo
      class="font-display font-extrabold text-5xl tracking-tighter uppercase text-white leading-none opacity-0 w-max"
      style="letter-spacing: -0.4em;"
    >
      &gt;_Q
    </div>
    <p
      class="font-mono text-brand text-xs uppercase tracking-widest mt-8 mb-3 hero-fade opacity-0"
    >
      Based in {CV_DATA.location}
    </p>
    <h1
      class="font-display text-3xl md:text-4xl font-bold leading-tight hero-fade opacity-0"
    >
      <span class="text-muted">Hey! I'm</span>
      {firstName}
      <br />
      <span class="text-outline-brand">{CV_DATA.nickname}</span>
    </h1>
    <p
      class="font-sans text-muted text-sm mt-4 leading-relaxed hero-fade opacity-0"
    >
      {CV_DATA.role}
    </p>
  </div>

  <About />

  <!-- Education card -->
  <div
    class="bg-white/[0.03] border border-white/10 rounded-2xl p-6 hero-fade opacity-0"
  >
    <p class="font-mono text-brand text-xs mb-2">{education.date}</p>
    <h4 class="font-display text-lg font-bold leading-tight mb-1">
      {education.degree}
    </h4>
    <p class="font-sans text-muted text-sm">{education.uni}</p>
    <p class="font-mono text-xs mt-3 opacity-50">GPA: {education.gpa}</p>
  </div>

  <SocialLinks />
  <HireMe />
</aside>
