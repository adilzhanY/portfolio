---
import { CV_DATA } from "../data/cv";

const { education } = CV_DATA;
---

<section id="experience" class="px-6 md:px-14 py-24 md:py-36">
  <div class="reveal-section mb-14 flex items-end justify-between">
    <h2 class="font-display font-bold tracking-tight text-4xl md:text-6xl">
      Experience<span class="text-brand">.</span>
    </h2>
    <div class="font-mono text-xs uppercase tracking-widest text-muted">
      (02)
    </div>
  </div>

  {
    CV_DATA.experience.map((exp) => (
      <div class="reveal-section">
        <div class="dot-rule w-full" />
        <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-8 py-10">
          <div class="md:col-span-4">
            <h3 class="font-display font-bold tracking-tight text-3xl md:text-4xl mb-2">
              {exp.company}
            </h3>
            <p class="text-light/80 font-light">{exp.role}</p>
            <p class="font-mono text-xs uppercase tracking-widest text-muted mt-3">
              {exp.date} — {exp.location}
            </p>
          </div>
          <ul class="md:col-span-8 space-y-4 text-light/70 font-light leading-relaxed max-w-2xl">
            {exp.bullets.map((bullet) => (
              <li class="flex items-start">
                <span class="mr-4 mt-2.5 block w-1 h-1 bg-brand shrink-0 rounded-full" />
                <span>{bullet}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    ))
  }

  <div class="reveal-section">
    <div class="dot-rule w-full"></div>
    <div class="grid grid-cols-1 md:grid-cols-12 gap-6 md:gap-8 py-10">
      <div class="md:col-span-4">
        <h3 class="font-display font-bold tracking-tight text-3xl md:text-4xl mb-2">
          Education
        </h3>
        <p class="font-mono text-xs uppercase tracking-widest text-muted mt-3">
          {education.date}
        </p>
      </div>
      <div class="md:col-span-8">
        <p class="text-light/90 text-xl font-light">{education.degree}</p>
        <p class="text-light/60 font-light mt-1">{education.uni}</p>
        <p class="font-mono text-xs uppercase tracking-widest text-muted mt-3">
          GPA {education.gpa}
        </p>
      </div>
    </div>
    <div class="dot-rule w-full"></div>
  </div>
</section>
