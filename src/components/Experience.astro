---
import { CV_DATA } from "../data/cv";
---

<section
  id="experience"
  class="bg-white text-dark rounded-2xl p-6 md:p-12 reveal-section"
>
  <div class="grow-line h-px bg-dark/20 w-full mb-12 origin-left"></div>
  <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
    <div
      class="md:col-span-4 font-mono text-xs uppercase tracking-widest text-dark/60"
    >
      (02) — Professional Work
    </div>
    <div class="md:col-span-8">
      {
        CV_DATA.experience.map((exp) => (
          <div class="mb-16 last:mb-0">
            <div class="flex flex-col md:flex-row md:items-end justify-between mb-8 border-b border-dark/10 pb-6">
              <div>
                <h3 class="font-display text-4xl md:text-6xl font-bold uppercase tracking-tighter mb-2">
                  {exp.company}
                </h3>
                <p class="font-mono text-lg font-bold">{exp.role}</p>
              </div>
              <div class="text-left md:text-right mt-4 md:mt-0 font-mono text-sm">
                <p>{exp.date}</p>
                <p class="text-dark/60">{exp.location}</p>
              </div>
            </div>
            <ul class="space-y-4 font-sans text-base md:text-lg leading-relaxed">
              {exp.bullets.map((bullet) => (
                <li class="flex items-start">
                  <span class="mr-4 mt-2 block w-1.5 h-1.5 bg-brand flex-shrink-0 rounded-full" />
                  <span>{bullet}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
