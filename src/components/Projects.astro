---
import { CV_DATA } from "../data/cv";
import ArrowRight from "./icons/ArrowRight.astro";
import ProjectShowcase from "./ProjectShowcase";
---

<section id="projects" class="px-6 md:px-14 py-24 md:py-36">
  <div
    class="reveal-section mb-14 grid grid-cols-1 lg:grid-cols-2 gap-10 items-end"
  >
    <div>
      <div class="font-mono text-xs uppercase tracking-widest text-muted mb-4">
        (01)
      </div>
      <h2 class="font-display font-bold tracking-tight text-4xl md:text-6xl">
        Selected work<span class="text-brand">.</span>
      </h2>
      <p class="mt-6 text-light/60 font-light max-w-md">
        A rotating look at what I've been building — hover to hold a card,
        click to open the repo.
      </p>
    </div>
    <!-- CardSwap positions itself against this panel's bottom-right corner -->
    <div
      class="relative hidden lg:block h-[420px] overflow-hidden rounded-2xl"
    >
      <ProjectShowcase client:visible />
    </div>
  </div>

  <div>
    {
      CV_DATA.projects.map((project, i) => (
        <article class="reveal-section group border-t border-transparent">
          <div class="dot-rule w-full" />
          <a
            href={project.link}
            target="_blank"
            rel="noopener noreferrer"
            class="hover-trigger grid grid-cols-1 md:grid-cols-12 gap-3 md:gap-8 items-baseline py-8 md:py-10 transition-colors duration-300 group-hover:bg-white/[0.025]"
          >
            <div class="md:col-span-1 font-mono text-sm text-brand">
              {String(i + 1).padStart(2, "0")}
            </div>
            <h3 class="md:col-span-4 font-display font-bold tracking-tight text-3xl md:text-5xl flex items-center gap-4">
              {project.title}
              <span class="hidden md:inline-block opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300 text-brand">
                <ArrowRight />
              </span>
            </h3>
            <p class="md:col-span-4 text-light/70 font-light leading-relaxed">
              {project.desc}
            </p>
            <p class="md:col-span-3 font-mono text-xs uppercase tracking-wider text-muted leading-relaxed">
              {project.tech}
            </p>
          </a>
        </article>
      ))
    }
    <div class="dot-rule w-full reveal-section"></div>
  </div>
</section>
