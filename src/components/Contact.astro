---
import { CV_DATA } from "../data/cv";
import ArrowRight from "./icons/ArrowRight.astro";
import RotatingText from "./RotatingText.astro";

const year = new Date().getFullYear();
const city = CV_DATA.location.split(",")[0];
const links = [
  { name: "Email", url: CV_DATA.contact.email, external: false },
  { name: "GitHub", url: CV_DATA.contact.github, external: true },
  { name: "LinkedIn", url: CV_DATA.contact.linkedin, external: true },
];
---

<footer id="contact" class="px-6 md:px-14 pt-24 md:pt-36 pb-10">
  <div class="reveal-section">
    <span class="pill mb-10">open to work <span aria-hidden="true">&rarr;</span></span>
    <h2
      class="font-display font-bold tracking-tight leading-[1.05] text-5xl md:text-8xl mb-8"
    >
      Let's build<br />
      <RotatingText words={["systems", "apps", "websites", "ideas"]} /><span
        class="text-brand">.</span
      >
    </h2>
    <p class="text-light/70 font-light text-lg md:text-xl max-w-md">
      Available for freelance and open to full-time opportunities.
    </p>
  </div>

  <div
    class="reveal-section mt-16 flex flex-col md:flex-row gap-4 md:gap-12 font-mono text-sm uppercase tracking-widest"
  >
    {
      links.map((link) => (
        <a
          href={link.url}
          target={link.external ? "_blank" : undefined}
          rel={link.external ? "noopener noreferrer" : undefined}
          class="hover-trigger group flex items-center gap-2 text-light/80 hover:text-brand transition-colors"
        >
          {link.name}
          <span class="opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0 transition-all">
            <ArrowRight />
          </span>
        </a>
      ))
    }
  </div>

  <div class="mt-24">
    <div class="dot-rule w-full"></div>
    <div
      class="pt-6 flex flex-col md:flex-row justify-between items-center gap-2 font-mono text-xs uppercase tracking-widest text-muted"
    >
      <div>&copy; {year} {CV_DATA.name} ({CV_DATA.nickname})</div>
      <div>Designed &amp; engineered in {city}</div>
    </div>
  </div>
</footer>
